{
  "base_model": "Qwen/Qwen2.5-7B-Instruct",
  "_alt_models": ["meta-llama/Meta-Llama-3.1-8B-Instruct", "microsoft/Phi-4-mini-instruct"],
  "output_dir": "out/adapter",
  "train_file": "data/train.jsonl",
  "val_file": "data/val.jsonl",
  "max_seq_len": 2048,

  "_comment_lora": "Low rank is deliberate. Style is a thin manifold; high rank risks the model memorizing CONTENT (facts/decisions) which the Excel says must live in RAG. r=16 captures voice without overfitting knowledge.",
  "lora_r": 16,
  "lora_alpha": 32,
  "lora_dropout": 0.05,
  "target_modules": ["q_proj", "k_proj", "v_proj", "o_proj", "gate_proj", "up_proj", "down_proj"],

  "load_in_4bit": true,
  "bnb_4bit_quant_type": "nf4",
  "bnb_4bit_compute_dtype": "bfloat16",
  "bnb_4bit_use_double_quant": true,

  "_comment_epochs": "2-3 epochs only. Style saturates fast; more epochs make it parrot training phrases verbatim and erode generalization. Watch val loss for the turn.",
  "num_train_epochs": 3,
  "per_device_train_batch_size": 4,
  "gradient_accumulation_steps": 4,
  "learning_rate": 1e-4,
  "lr_scheduler_type": "cosine",
  "warmup_ratio": 0.03,
  "weight_decay": 0.0,
  "logging_steps": 10,
  "eval_strategy": "steps",
  "eval_steps": 50,
  "save_steps": 50,
  "save_total_limit": 3,
  "load_best_model_at_end": true,
  "metric_for_best_model": "eval_loss",
  "bf16": true,
  "gradient_checkpointing": true,
  "train_on_responses_only": true,
  "seed": 7
}
